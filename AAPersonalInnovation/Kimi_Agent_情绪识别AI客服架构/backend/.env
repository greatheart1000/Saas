# ==================== 应用配置 ====================
APP_NAME=Kimi Customer Service
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0

# ==================== API配置 ====================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# ==================== 数据库配置 ====================
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/kimi_cs
DATABASE_ECHO=false

# ==================== Redis配置 ====================
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# ==================== LLM配置 ====================
LLM_PROVIDER=zhipu

# 智谱AI配置 (GLM-5)
ZHIPU_API_KEY=b47777cc5e654fbf96265be8c5398097.lDBejVEPN5RGMlHu
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-5
ZHIPU_EMBEDDING_MODEL=embedding-v2

# Kimi配置（备用）
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-128k
KIMI_EMBEDDING_MODEL=embedding-v2

# OpenAI配置（备用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ==================== 上下文窗口配置 ====================
# 不同任务的上下文消息数
CONTEXT_SENTIMENT_LIMIT=5         # 情绪分析：最近5条
CONTEXT_INTENT_LIMIT=5            # 意图识别：最近5条
CONTEXT_RESPONSE_LIMIT=10         # 生成回复：最近10条
CONTEXT_SUMMARY_LIMIT=20          # 生成总结：最近20条
CONTEXT_MAX_TOKENS=4000           # 最大token数

# ==================== 自动摘要配置 ====================
SUMMARY_TRIGGER_MESSAGE_COUNT=15  # 消息数达到15条时触发摘要
SUMMARY_TRIGGER_TIME_MINUTES=10   # 每10分钟触发一次摘要
SUMMARY_AUTO_SUMMARIZE=true       # 启用自动摘要
SUMMARY_PRESERVE_KEY_MESSAGES=3   # 摘要后保留最近3条消息

# ==================== Persona拟人化配置 ====================
DEFAULT_PERSONA=friendly           # 默认人格：亲切友好
PERSONA_ENABLED=true               # 启用拟人化回复
PERSONA_ALLOWED_TYPES=["friendly", "cute", "mature", "professional", "humorous"]

# ==================== 向量数据库配置 ====================
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=knowledge_base

# ==================== 嵌入模型配置 ====================
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu  # cuda 或 cpu
EMBEDDING_BATCH_SIZE=32

# ==================== RAG配置 ====================
RAG_TOP_K=5                      # 检索返回数量
RAG_SCORE_THRESHOLD=0.7          # 相似度阈值
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_HYBRID_ALPHA=0.5             # 向量和BM25的权重混合比例

# ==================== 记忆管理配置 ====================
MEMORY_SHORT_TERM_LIMIT=10        # 短期记忆保留最近N条消息
MEMORY_LONG_TERM_LIMIT=100        # 长期记忆保留N个关键事实
MEMORY_SUMMARY_THRESHOLD=20       # 触发总结的消息数阈值

# ==================== Agent配置 ====================
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=30.0

# ==================== 转人工配置 ====================
HANDOFF_SENTIMENT_THRESHOLD=0.7  # 情绪分数阈值
HANDOFF_COMPLEXITY_THRESHOLD=0.8 # 问题复杂度阈值
HANDOFF_REPEAT_THRESHOLD=3       # 重复提问次数阈值

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ==================== 安全配置 ====================
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
